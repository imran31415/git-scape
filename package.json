{
  "name": "threatscape",
  "version": "1.0.0",
  "description": "Turn any GitHub repository into a living 3D cyber-city and watch its threats materialize. 100% in-browser: Go/WASM security engine, Three.js viewport, zero backend.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "wasm:build": "bash scripts/build-wasm.sh",
    "go:test": "cd scanner && go test ./...",
    "e2e": "playwright test"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.170.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
